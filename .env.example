# =============================================================================
# GitLab Provisioner — Environment Variables
# =============================================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in every value in .env
# 3. NEVER commit .env to Git — it contains secrets
# =============================================================================

# --- GitLab connection ---
GITLAB_URL=http://gitlab.local
# Your GitLab Personal Access Token
# How to get: GitLab → Avatar (top-right) → Edit Profile → Access Tokens
# → Add new token → Name: provisioner → Scopes: tick "api" + "write_repository" → Create
GITLAB_PAT=glpat-XXXXXXXXXXXXXXXXXXXX

# --- GitHub credentials ---
# Same PAT you already use in your CI/CD variables
GITHUB_PAT=ghp_XXXXXXXXXXXXXXXXXXXX

# --- Git identity used by the sync runner ---
# Must match exactly what you have in GIT_SYNC_USER and GIT_SYNC_EMAIL CI variables
GIT_SYNC_USER=Your Sync Bot Name
GIT_SYNC_EMAIL=sync@yourcompany.com

# --- Sync pipeline settings ---
# Must match exactly what you have in SYNC_BRANCH_PREFIX CI variable
SYNC_BRANCH_PREFIX=github-sync

# Must match exactly what you have in SYNC_SOURCE_BRANCH CI variable
SYNC_SOURCE_BRANCH=main

# The tag on your GitLab runner that runs sync jobs
GITLAB_RUNNER_TAG=sync

# --- Central CI template project ---
# Numeric project ID of your sync-templates project in GitLab
# Find it: open sync-templates project → Settings → General → Project ID (shown at top)
TEMPLATE_PROJECT_ID=
TEMPLATE_PROJECT_REF=main

# --- Web UI settings ---
PROVISIONER_PORT=5001
# DEFAULT_GROUP_PATH pre-selects a group in the UI dropdown (use the group slug, e.g. "clients")
DEFAULT_GROUP_PATH=